<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flow— Login</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Syne:wght@700;800&display=swap"
        rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        :root {
            --bg: #0D0D0E;
            --surface: #16181c;
            --surface-2: #1e2026;
            --border: rgba(255, 255, 255, 0.07);
            --border-hover: rgba(255, 255, 255, 0.14);
            --text: #f0f0ee;
            --muted: #7a7c82;
            --accent: #f59e0b;
            --accent-glow: #343c312e; /*future work*/
            --green: #3ecf8e;
            --red: #f26c6c;
            --amber: #f5a623;
            --radius: 14px;
        }

        body {
            font-family: Inter, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.25rem 2rem;
            border-bottom: 1px solid var(--border);
            background: rgba(14, 15, 17, .9);
            backdrop-filter: blur(12px);
        }

        .logo {
            font-family: Syne, sans-serif;
            font-size: 1.35rem;
            font-weight: 800;
        }

        .logo span {
            color: #22c55e;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: .3rem;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--muted);
            padding: .45rem .85rem;
            border-radius: 8px;
            font-size: .9rem;
            transition: .15s;
        }

        .nav-links a:hover,
        .nav-links .active {
            background: var(--surface);
            color: var(--text);
        }

        main {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem;
        }

        .card {
            width: 100%;
            max-width: 420px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 2rem;
        }

        h1 {
            font-family: Syne, sans-serif;
            font-size: 2rem;
            margin-bottom: .5rem;
        }

        .subtitle {
            color: var(--muted);
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .alert {
            background: rgba(242, 108, 108, .12);
            border: 1px solid rgba(242, 108, 108, .35);
            color: #ffb4b4;
            padding: .9rem 1rem;
            border-radius: 10px;
            margin-bottom: 1.2rem;
            font-size: .9rem;
        }

        label {
            display: block;
            margin-bottom: .45rem;
            font-size: .9rem;
            font-weight: 500;
        }

        .input-group {
            margin-bottom: 1.25rem;
        }

        input[type=email],
        input[type=password] {
            width: 100%;
            padding: .85rem 1rem;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            font-size: .95rem;
            outline: none;
            transition: .2s;
        }

        input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 4px var(--accent-glow);
        }

        .row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            font-size: .88rem;
        }

        .row a {
            color: var(--accent);
            text-decoration: none;
        }

        .row a:hover {
            text-decoration: underline;
        }

        .checkbox {
            display: flex;
            align-items: center;
            gap: .45rem;
            color: var(--muted);
        }

        .btn {
            width: 100%;
            padding: .9rem;
            background: var(--accent);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: .95rem;
            font-weight: 600;
            cursor: pointer;
            transition: .2s;
        }

        .btn:hover {
            background: #f44f02;
            transform: translateY(-1px);
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.75rem 0;
            color: var(--muted);
            font-size: .8rem;
        }

        .divider::before,
        .divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .register {
            text-align: center;
            font-size: .9rem;
            color: var(--muted);
        }

        .register a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
        }

        footer {
            padding: 1.5rem;
            text-align: center;
            color: var(--muted);
            border-top: 1px solid var(--border);
            font-size: .8rem;
        }

        @media(max-width:600px) {
            nav {
                padding: 1rem;
            }

            .card {
                padding: 1.5rem;
            }
        }
    </style>
</head>

<body>

    <nav>
        <div class="logo">Spen<span>za</span></div>

        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a class="active" href="/login">Login</a></li>
            <li><a href="/register">Register</a></li>
        </ul>
    </nav>

    <main>

        <div class="card">

            <h1>Welcome back</h1>
            <p class="subtitle">Log in to continue managing your finances.</p>

            <% if(locals.error){ %>
                <div class="alert">
                    <%= locals.error %>
                </div>
                <% } %>

                    <form action="/login" method="POST">

                        <div class="input-group">
                            <label>Email</label>
                            <input type="email" name="email" required autocomplete="email"
                                placeholder="you@example.com">
                        </div>

                        <div class="input-group">
                            <label>Password</label>
                            <input type="password" name="password" required autocomplete="current-password"
                                placeholder="••••••••">
                        </div>

                        <div class="row">
                            <label class="checkbox">
                                <input type="checkbox" name="remember">
                                <span>Remember me</span>
                            </label>

                            <a href="/forgot-password">Forgot password?</a>
                        </div>

                        <button class="btn" type="submit">
                            Log in
                        </button>

                    </form>

                    <div class="divider">
                        OR
                    </div>

                    <div class="register">
                        Don't have an account?
                        <a href="/register">Create one</a>
                    </div>

        </div>

    </main>

    <footer>
        &copy; <%= new Date().getFullYear() %> Spenza — Personal Finance Tracker
    </footer>

</body>

</html>