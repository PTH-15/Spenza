<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flow — Register</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Syne:wght@700;800&display=swap"
        rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        :root {
            --bg: #0e0f11;
            --surface: #16181c;
            --surface-2: #1e2026;
            --border: rgba(255, 255, 255, .07);
            --border-hover: rgba(255, 255, 255, .14);
            --text: #f0f0ee;
            --muted: #7a7c82;
            --accent: #7c6ef5;
            --accent-glow: rgba(124, 110, 245, .18);
            --red: #f26c6c;
            --green: #3ecf8e;
            --radius: 14px;
        }

        body {
            font-family: Inter, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.25rem 2rem;
            border-bottom: 1px solid var(--border);
            background: rgba(14, 15, 17, .9);
            backdrop-filter: blur(12px);
        }

        .logo {
            font-family: Syne, sans-serif;
            font-size: 1.35rem;
            font-weight: 800;
        }

        .logo span {
            color: var(--accent);
        }

        .nav-links {
            display: flex;
            gap: .3rem;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--muted);
            padding: .45rem .85rem;
            border-radius: 8px;
            transition: .15s;
        }

        .nav-links a:hover,
        .nav-links .active {
            background: var(--surface);
            color: var(--text);
        }

        main {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem;
        }

        .card {
            width: 100%;
            max-width: 460px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 2rem;
        }

        h1 {
            font-family: Syne, sans-serif;
            font-size: 2rem;
            margin-bottom: .5rem;
        }

        .subtitle {
            color: var(--muted);
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .alert {
            background: rgba(242, 108, 108, .12);
            border: 1px solid rgba(242, 108, 108, .3);
            color: #ffb5b5;
            padding: .9rem;
            border-radius: 10px;
            margin-bottom: 1.2rem;
        }

        .success {
            background: rgba(62, 207, 142, .12);
            border: 1px solid rgba(62, 207, 142, .3);
            color: #8ff0c0;
            padding: .9rem;
            border-radius: 10px;
            margin-bottom: 1.2rem;
        }

        .group {
            margin-bottom: 1.15rem;
        }

        label {
            display: block;
            margin-bottom: .45rem;
            font-size: .9rem;
            font-weight: 500;
        }

        input {
            width: 100%;
            padding: .85rem 1rem;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            font-size: .95rem;
            outline: none;
            transition: .2s;
        }

        input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 4px var(--accent-glow);
        }

        small {
            display: block;
            margin-top: .4rem;
            color: var(--muted);
            font-size: .75rem;
        }

        .btn {
            width: 100%;
            padding: .9rem;
            margin-top: .5rem;
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: .95rem;
            font-weight: 600;
            cursor: pointer;
            transition: .2s;
        }

        .btn:hover {
            background: #6a5ee0;
            transform: translateY(-1px);
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.8rem 0;
            font-size: .8rem;
            color: var(--muted);
        }

        .divider::before,
        .divider::after {
            content: "";
            height: 1px;
            flex: 1;
            background: var(--border);
        }

        .login {
            text-align: center;
            color: var(--muted);
            font-size: .9rem;
        }

        .login a {
            color: var(--accent);
            font-weight: 600;
            text-decoration: none;
        }

        footer {
            padding: 1.5rem;
            text-align: center;
            border-top: 1px solid var(--border);
            font-size: .8rem;
            color: var(--muted);
        }

        @media(max-width:600px) {
            nav {
                padding: 1rem;
            }

            .card {
                padding: 1.5rem;
            }
        }
    </style>
</head>

<body>

    <nav>
        <div class="logo">fl<span>o</span></div>

        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/login">Login</a></li>
            <li><a href="/register" class="active">Register</a></li>
        </ul>

    </nav>

    <main>

        <div class="card">

            <h1>Create your account</h1>

            <p class="subtitle">
                Join Flow and start tracking your income, expenses and monthly budget.
            </p>

            <% if(locals.error){ %>
                <div class="alert">
                    <%= locals.error %>
                </div>
                <% } %>

                    <% if(locals.success){ %>
                        <div class="success">
                            <%= locals.success %>
                        </div>
                        <% } %>

                            <form action="/register" method="POST">

                                <div class="group">
                                    <label>Full Name</label>
                                    <input type="text" name="name" required placeholder="John Doe" autocomplete="name">
                                </div>

                                <div class="group">
                                    <label>Email</label>
                                    <input type="email" name="email" required placeholder="john@example.com"
                                        autocomplete="email">
                                </div>

                                <div class="group">
                                    <label>Password</label>
                                    <input type="password" name="password" required placeholder="Minimum 8 characters"
                                        autocomplete="new-password">
                                    <small>Use at least 8 characters.</small>
                                </div>

                                <div class="group">
                                    <label>Confirm Password</label>
                                    <input type="password" name="confirmPassword" required
                                        placeholder="Re-enter password" autocomplete="new-password">
                                </div>

                                <button class="btn" type="submit">
                                    Create Account
                                </button>

                            </form>

                            <div class="divider">
                                OR
                            </div>

                            <div class="login">
                                Already have an account?
                                <a href="/login">Log in</a>
                            </div>

        </div>

    </main>

    <footer>
        &copy; <%= new Date().getFullYear() %> Flow — Personal Finance Tracker
    </footer>

</body>

</html>